# ZAPF ROYALE — web/ Umgebungsvariablen (alle NEXT_PUBLIC_, landen im Client-Bundle)

# Game-Server (Fastify + WebSocket). WS-URL wird automatisch daraus abgeleitet (http->ws).
NEXT_PUBLIC_SERVER_URL=http://localhost:8787

# Solana RPC (devnet!)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Programm-ID des Anchor-Programms (nach `anchor deploy` eintragen).
# Platzhalter = System Program, damit die App auch ohne Deployment startet.
NEXT_PUBLIC_PROGRAM_ID=11111111111111111111111111111111
