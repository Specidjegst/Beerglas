# --- Server ---
# HTTP/WebSocket port
PORT=8787
# Directory for the JSON file store (lobbies, VRF randomness, join timestamps)
DATA_DIR=./data
# Secret for HMAC-signed auth tokens (hex or any string). Random per boot if unset
# (tokens then become invalid across restarts).
AUTH_SECRET=

# --- Chain ---
# "anchor" = talk to the real program on RPC_URL, "mock" = in-memory chain (offline dev/tests)
CHAIN=mock
# Solana RPC endpoint (devnet)
RPC_URL=https://api.devnet.solana.com
# Deployed zapf_royale program id
PROGRAM_ID=Zapf1111111111111111111111111111111111111111
# result_authority keypair: JSON array (solana-keygen format, 64 bytes) OR base58-encoded secret key.
# Required for CHAIN=anchor. For CHAIN=mock an ephemeral keypair is generated if unset.
RESULT_AUTHORITY_KEYPAIR=
# Treasury pubkey receiving the 4% fee at settlement
TREASURY=

# --- VRF (MagicBlock Ephemeral VRF) ---
# Oracle queue account the create_lobby ix sends its randomness request to.
# Default: MagicBlock's devnet default queue.
ORACLE_QUEUE=GKE6d7iv8kCBrsxr78W3xVdjGLLLJnxsGiuzrsZCGEvb

# --- Game ---
# Seats per lobby (MVP: 5)
LOBBY_SIZE=5
# Entry fee in lamports for auto-created lobbies (0.05 SOL)
DEFAULT_ENTRY_FEE_LAMPORTS=50000000
